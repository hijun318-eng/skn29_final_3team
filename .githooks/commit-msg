#!/bin/sh
set -eu

repo_root=$(git rev-parse --show-toplevel)
validator="$repo_root/scripts/validate_commit_message.py"

if command -v python >/dev/null 2>&1; then
  exec python "$validator" "$1"
fi

if command -v py >/dev/null 2>&1; then
  exec py -3 "$validator" "$1"
fi

echo "commit-msg: Python 3 is required to validate the commit message." >&2
exit 1
